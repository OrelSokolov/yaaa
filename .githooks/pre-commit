#!/bin/bash
set -euo pipefail

# Run only if Cargo.toml or Cargo.lock are staged for commit.
if ! git diff --cached --name-only | grep -qE '^(Cargo\.toml|Cargo\.lock)$'; then
    exit 0
fi

echo 'Pre-commit: checking Cargo.lock consistency...'

# Verify that Cargo.lock is in sync with Cargo.toml.
# This catches version bumps and other lock-file drift before they break CI.
if ! cargo metadata --format-version=1 --locked >/dev/null 2>&1; then
    echo ''
    echo 'Error: Cargo.lock is out of sync with Cargo.toml.'
    echo 'Run the following command to fix it:'
    echo ''
    echo '    cargo update -p yaaa'
    echo ''
    exit 1
fi

echo 'Pre-commit: Cargo.lock is consistent.'
